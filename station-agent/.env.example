### Station Agent (host-mode) .env example

# REQUIRED
STATION_ID=00000000-0000-0000-0000-000000000001
UPDATE_SERVER_URL=https://alphaoflogic-ua.github.io/smart-home-updates/release.json

# SCHEDULING
CHECK_INTERVAL_MINUTES=60

# DOCKER COMPOSE PROJECT
# Путь к корню проекта, где лежит docker-compose.prod.yml
COMPOSE_PROJECT_PATH=~/smart-home
COMPOSE_FILE=docker-compose.prod.yml

# VERSIONING & BEHAVIOR
CURRENT_VERSION=0.0.1
AUTO_UPDATE=true

# BOOTSTRAP
# If true, agent will pull and start the docker compose stack on first launch if it's not running
BOOTSTRAP_ON_START=true

# HEALTHCHECK
# Если агент вне Docker, укажите URL, доступный с хоста
HEALTHCHECK_URL=http://localhost:3000/health

# TIMINGS (optional)
STABILIZATION_SECONDS=45
REQUEST_TIMEOUT_MS=10000

# DATA (optional)
# Каталог для хранения состояния агента (rollback.json, current_version.txt, override.yml)
DATA_DIR=~/station-agent-data

# HTTP SERVER (optional)
# 127.0.0.1 = only localhost (recommended for production), 0.0.0.0 = all interfaces
HOST=127.0.0.1
PORT=3000

# SECURITY (optional)
# Protects POST /update and POST /rollback endpoints
# Generate: openssl rand -hex 32
AGENT_TOKEN=

# PRIVATE DOCKER REGISTRY AUTH (optional; Docker Hub by default)
DOCKER_USERNAME=
DOCKER_TOKEN=
# DOCKER_REGISTRY=registry-1.docker.io
